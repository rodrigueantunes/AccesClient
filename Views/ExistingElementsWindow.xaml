<Window x:Class="AccesClientWPF.Views.ExistingElementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AccesClientWPF.Converters"
        Title="Éléments existants"
        Width="700" Height="550"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/FluentTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <conv:FileTypeToIconConverter x:Key="FileTypeToIconConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource FluentSidebarBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,10">
            <DockPanel>
                <TextBlock Text="Client :" Foreground="{StaticResource FluentTextOnDarkBrush}" FontWeight="Bold" FontSize="16" Margin="0,0,10,0" FontFamily="{StaticResource FluentFont}"/>
                <TextBlock Text="{Binding ClientName}" Foreground="{StaticResource FluentTextOnDarkBrush}" FontSize="16" FontFamily="{StaticResource FluentFont}"/>
            </DockPanel>
        </Border>

        <!-- Tree : Racine + Rangements -->
        <Border Grid.Row="1" Background="{StaticResource FluentCardBrush}" CornerRadius="10" Padding="10" BorderBrush="{StaticResource LightBorderBrush}" BorderThickness="1">
            <TreeView x:Name="Tree"
                      ItemsSource="{Binding Nodes}"
                      SelectedItemChanged="Tree_SelectedItemChanged">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="18" Height="18" Margin="0,0,8,0"
                                   Source="{Binding File, Converter={StaticResource FileTypeToIconConverter}}"/>
                            <TextBlock Text="{Binding Display}" FontWeight="{Binding FontWeight}" Foreground="{StaticResource DarkTextBrush}" FontFamily="{StaticResource FluentFont}"/>
                            <TextBlock Text="{Binding TypeText}" Foreground="{StaticResource LightTextBrush}" Margin="10,0,0,0" FontFamily="{StaticResource FluentFont}"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="2" Margin="0,10,0,0">
            <Button Content="Ajouter" Width="110" Margin="5" Click="AddElement_Click" Style="{StaticResource FluentButton}"/>
            <Button Content="Modifier" Width="110" Margin="5" Click="EditElement_Click" Style="{StaticResource FluentButton}"/>
            <Button Content="Supprimer" Width="110" Margin="5" Click="DeleteElement_Click" Style="{StaticResource FluentButton}"/>
            <Button Content="Fermer" Width="110" Margin="5" Click="Close_Click" Style="{StaticResource FluentSubtleButton}"/>
        </StackPanel>
    </Grid>
</Window>