<Window x:Class="AccesClientWPF.Views.RdsAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion des comptes de connexion" Height="400" Width="600"
            Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/FluentTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <StackPanel Margin="10">
            <TextBlock Text="Comptes de connexion" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>

            <Border Background="{StaticResource FluentCardBrush}" BorderBrush="{StaticResource LightBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10">
                <ListView ItemsSource="{Binding RdsAccounts}"
                          SelectedItem="{Binding SelectedRdsAccount}"
                          Height="200"
                          MouseDoubleClick="ListView_MouseDoubleClick"
                          Background="Transparent"
                          BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Description" DisplayMemberBinding="{Binding Description}" Width="150"/>
                            <GridViewColumn Header="IP/DNS" DisplayMemberBinding="{Binding IpDns}" Width="150"/>
                            <GridViewColumn Header="Utilisateur" DisplayMemberBinding="{Binding NomUtilisateur}" Width="150"/>
                            <GridViewColumn Header="Création" DisplayMemberBinding="{Binding DateCreation}" Width="150"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="Ajouter" Command="{Binding AddCommand}" Width="100" Margin="5" Style="{StaticResource FluentButton}"/>
                <Button Content="Modifier" Command="{Binding EditCommand}" Width="100" Margin="5" Style="{StaticResource FluentButton}"/>
                <Button Content="Supprimer" Command="{Binding DeleteCommand}" Width="100" Margin="5" Style="{StaticResource FluentDangerButton}"/>
                <Button Content="Fermer" Command="{Binding CloseCommand}" Width="100" Margin="5" Style="{StaticResource FluentSubtleButton}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>