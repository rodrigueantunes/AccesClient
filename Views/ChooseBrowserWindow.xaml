<Window x:Class="AccesClientWPF.Views.ChooseBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choisir un navigateur" Height="200" Width="400"
        Background="{StaticResource WindowBackgroundBrush}" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/FluentTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Navigateur détecté :" FontSize="16" FontWeight="Bold" Foreground="{StaticResource MediumTextBrush}" Margin="0,0,0,10" FontFamily="{StaticResource FluentFont}"/>

            <!-- ComboBox -->
            <ComboBox x:Name="BrowsersCombo" Width="300" Margin="0,5" 
                      Background="{StaticResource FluentCardBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" FontFamily="{StaticResource FluentFont}"/>

            <!-- Boutons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10" >
                <Button x:Name="OpenOnceButton" Content="Ouvrir une fois" Width="120" Margin="5" Style="{StaticResource FluentButton}"/>
                <Button x:Name="SetDefaultButton" Content="Définir par défaut" Width="140" Margin="5" Style="{StaticResource FluentButton}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
