<Window x:Class="AccesClientWPF.Views.AddEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AccesClientWPF.Converters"
        Title="Ajouter un élément" Height="Auto" Width="900"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/FluentTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <conv:FileTypeToIconConverter x:Key="FileTypeToIconConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Nom -->
            <RowDefinition Height="Auto"/>
            <!-- Type -->
            <RowDefinition Height="Auto"/>
            <!-- Client -->
            <RowDefinition Height="Auto"/>
            <!-- Rangement -->
            <RowDefinition Height="Auto"/>
            <!-- RDS / Mot de passe -->
            <RowDefinition Height="Auto"/>
            <!-- AnyDesk -->
            <RowDefinition Height="Auto"/>
            <!-- VPN -->
            <RowDefinition Height="Auto"/>
            <!-- Dossier -->
            <RowDefinition Height="Auto"/>
            <!-- Fichier -->
            <RowDefinition Height="Auto"/>
            <!-- Boutons -->
        </Grid.RowDefinitions>

        <TextBlock Text="Nom :" Grid.Row="0" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
        <TextBox x:Name="TxtName" Grid.Row="0" Margin="100,0,0,5" Style="{StaticResource FluentTextBox}"/>

        <TextBlock Text="Type :" Grid.Row="1" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
        <ComboBox x:Name="CmbType" Grid.Row="1" Margin="100,0,0,5" Background="{StaticResource FluentCardBrush}" 
                  BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" FontFamily="{StaticResource FluentFont}"
                  SelectionChanged="CmbType_SelectionChanged">
            <ComboBoxItem Content="Bureau à distance" Tag="RDS"/>
            <ComboBoxItem Content="VPN" Tag="VPN"/>
            <ComboBoxItem Content="Anydesk" Tag="AnyDesk"/>
            <ComboBoxItem Content="Dossier" Tag="Dossier"/>
            <ComboBoxItem Content="Fichier" Tag="Fichier"/>
            <ComboBoxItem Content="Mot de passe" Tag="MotDePasse"/>
            <ComboBoxItem Content="Rangement (niveau 2)" Tag="Rangement"/>
        </ComboBox>

        <TextBlock Text="Client :" Grid.Row="2" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
        <ComboBox x:Name="CmbClient" Grid.Row="2" Margin="100,0,0,5" Background="{StaticResource FluentCardBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" FontFamily="{StaticResource FluentFont}"
                  DisplayMemberPath="Name"/>

        <TextBlock Text="Rangement :" Grid.Row="3" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
        <ComboBox x:Name="CmbRangementParent"
                  Grid.Row="3"
                  Margin="100,0,0,5"
                  Background="{StaticResource FluentCardBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  FontFamily="{StaticResource FluentFont}"/>

        <!-- Section RDS -->
        <StackPanel x:Name="PanelRDS" Grid.Row="4" Orientation="Vertical" Visibility="Collapsed">
            <TextBlock Text="IP/DNS :" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
            <TextBox x:Name="TxtIpDns" Margin="100,0,0,5" Style="{StaticResource FluentTextBox}"/>

            <TextBlock Text="Nom d'utilisateur :" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
            <TextBox x:Name="TxtUsername" Margin="100,0,0,5" Style="{StaticResource FluentTextBox}"/>

            <TextBlock Text="Mot de passe :" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
            <PasswordBox x:Name="TxtPassword" Margin="100,0,0,5" Style="{StaticResource FluentPasswordBox}"/>
        </StackPanel>

        <!-- Section AnyDesk -->
        <StackPanel x:Name="PanelAnyDesk" Grid.Row="5" Orientation="Vertical" Visibility="Collapsed">
            <TextBlock Text="Identifiant :" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
            <TextBox x:Name="TxtAnydeskId" Margin="100,0,0,5" Style="{StaticResource FluentTextBox}"/>

            <TextBlock Text="Mot de passe (facultatif) :" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
            <PasswordBox x:Name="TxtAnydeskPassword" Margin="100,0,0,5" Style="{StaticResource FluentPasswordBox}"/>

            <TextBlock Text="Utilisateur Windows (facultatif) :" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
            <TextBox x:Name="TxtWindowsUsername" Margin="100,0,0,5" Style="{StaticResource FluentTextBox}"/>

            <TextBlock Text="Mot de passe Windows (facultatif) :" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
            <PasswordBox x:Name="TxtWindowsPassword" Margin="100,0,0,5" Style="{StaticResource FluentPasswordBox}"/>
        </StackPanel>

        <!-- Section VPN -->
        <StackPanel x:Name="PanelVPN" Grid.Row="6" Orientation="Vertical" Visibility="Collapsed">
            <TextBlock Text="Chemin de l'exécutable :" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="TxtVpnPath" Width="400" Style="{StaticResource FluentTextBox}" Margin="100,0,0,5"/>
                <Button Content="Parcourir" Width="100" Margin="5" Click="BrowseVpnExecutable_Click" Style="{StaticResource FluentButton}"/>
            </StackPanel>
        </StackPanel>

        <!-- Section Dossier -->
        <StackPanel x:Name="PanelFolder" Grid.Row="7" Orientation="Vertical" Visibility="Collapsed">
            <TextBlock Text="Chemin du dossier :" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="TxtFolderPath" Width="400" Style="{StaticResource FluentTextBox}" Margin="100,0,0,5"/>
                <Button Content="Parcourir" Width="100" Margin="5" Click="BrowseFolder_Click" Style="{StaticResource FluentButton}"/>
            </StackPanel>
        </StackPanel>

        <!-- Section Fichier -->
        <StackPanel x:Name="PanelFile" Grid.Row="8" Orientation="Vertical" Visibility="Collapsed">
            <TextBlock Text="Chemin du fichier :" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="TxtFilePath" Width="400" Style="{StaticResource FluentTextBox}" Margin="100,0,0,5"/>
                <Button Content="Parcourir" Width="100" Margin="5" Click="BrowseFile_Click" Style="{StaticResource FluentButton}"/>
            </StackPanel>

            <TextBlock Text="Icône personnalisée (optionnelle) :" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="TxtIconPath" Width="400" Style="{StaticResource FluentTextBox}" Margin="100,0,0,5"/>
                <Button Content="Parcourir" Width="100" Margin="5" Click="BrowseIcon_Click" Style="{StaticResource FluentButton}"/>
            </StackPanel>

            <Image x:Name="IconPreview" Width="48" Height="48" Margin="100,5,0,5" Stretch="Uniform"
                   Visibility="Collapsed" HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- Section Mot de passe -->
        <StackPanel x:Name="PanelPassword" Grid.Row="4" Orientation="Vertical" Visibility="Collapsed">
            <TextBlock Text="Nom d'utilisateur :" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
            <TextBox x:Name="TxtPasswordUser" Margin="100,0,0,5" Style="{StaticResource FluentTextBox}"/>
            
            <TextBlock Text="Mot de passe :" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
            <PasswordBox x:Name="TxtPasswordPass" Margin="100,0,0,5" Style="{StaticResource FluentPasswordBox}"/>
        </StackPanel>

        <!-- Boutons -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Éléments existants" Width="170" Margin="5" Click="ShowExistingElements_Click" Style="{StaticResource FluentButton}"/>
            <Button Content="Annuler" Width="110" Margin="5" Click="Cancel_Click" Style="{StaticResource FluentSubtleButton}"/>
            <Button Content="Enregistrer" Width="110" Margin="5" Click="Save_Click" Style="{StaticResource FluentButton}"/>
        </StackPanel>
    </Grid>
</Window>