<Window x:Class="AccesClientWPF.Views.ClientManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion des Clients"
        Background="{StaticResource FluentSurfaceBrush}"
        WindowStartupLocation="CenterScreen"
        Width="780" Height="560"
        MinWidth="500" MinHeight="400"
        ResizeMode="CanResize"
        FontFamily="{StaticResource FluentFont}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/FluentTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="200"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource FluentCard}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Ajouter un client" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"
                           Foreground="{StaticResource FluentTextPrimaryBrush}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtClientName" Style="{StaticResource FluentTextBox}"
                             VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                        <TextBlock Text="Acronyme" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"
                                   Foreground="{StaticResource FluentTextSecondaryBrush}"/>
                        <TextBox x:Name="TxtAcronym" Style="{StaticResource FluentTextBox}" Width="60"
                                 MaxLength="3" CharacterCasing="Upper" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="Ajouter" Grid.Column="2" Margin="8,0,0,0"
                            Click="AddClient_Click" Style="{StaticResource FluentButton}"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource FluentCard}" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ListView x:Name="LstClients" BorderThickness="0" Background="Transparent"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Padding="4">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd" CornerRadius="6" Padding="6,6" Background="Transparent"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource LightGrayBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource VeryLightBlueBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="42" Height="30" CornerRadius="4"
                                        Background="{StaticResource FluentBrandBrush}" Margin="0,0,10,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Acronym}" Foreground="White"
                                               FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                           FontSize="13" Foreground="{StaticResource FluentTextPrimaryBrush}"/>

                                <Button Grid.Column="2" ToolTip="Modifier"
                                        Click="EditClient_Click"
                                        Style="{StaticResource FluentSubtleButton}"
                                        VerticalAlignment="Center" Padding="6,4" Margin="4,0">
                                    <Path Data="M3,17.25V21h3.75L17.81,9.94l-3.75-3.75L3,17.25Z M20.71,7.04c.39-.39.39-1.02,0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41,0l-1.83,1.83l3.75,3.75L20.71,7.04Z"
                                          Fill="{StaticResource FluentTextSecondaryBrush}"
                                          Width="16" Height="16" Stretch="Uniform"/>
                                </Button>

                                <Button Grid.Column="3" ToolTip="Ouvrir le dossier Fiches de fin de développement"
                                        Click="OpenClientFolder_Click" Tag="{Binding Acronym}"
                                        Style="{StaticResource FluentSubtleButton}"
                                        VerticalAlignment="Center" Padding="6,4">
                                    <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                                          Fill="{StaticResource FluentTextSecondaryBrush}"
                                          Width="16" Height="16" Stretch="Uniform"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,8,0">
                    <Button Click="MoveUpClient_Click" Style="{StaticResource FluentSubtleButton}"
                            Width="36" Height="36" Margin="0,2" ToolTip="Monter">
                        <Path Data="M7.41,15.41L12,10.83L16.59,15.41L18,14L12,8L6,14L7.41,15.41Z"
                              Fill="{StaticResource FluentTextSecondaryBrush}" Width="14" Height="14" Stretch="Uniform"/>
                    </Button>
                    <Button Click="MoveDownClient_Click" Style="{StaticResource FluentSubtleButton}"
                            Width="36" Height="36" Margin="0,2" ToolTip="Descendre">
                        <Path Data="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z"
                              Fill="{StaticResource FluentTextSecondaryBrush}" Width="14" Height="14" Stretch="Uniform"/>
                    </Button>
                    <Border Height="1" Background="{StaticResource FluentDividerBrush}" Margin="4,6"/>
                    <Button x:Name="BtnSort" Click="SortClients_Click" Style="{StaticResource FluentSubtleButton}"
                            Width="36" Height="36" Margin="0,2" ToolTip="Trier A-Z">
                        <Path x:Name="SortIcon"
                              Data="M3,13H15V11H3M3,6V8H21V6M3,18H9V16H3V18Z"
                              Fill="{StaticResource FluentTextSecondaryBrush}" Width="14" Height="14" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0" Cursor="">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <Button Content="Éléments existants" Margin="0,0,6,0" Click="ViewElements_Click"
                        Style="{StaticResource FluentButton}"/>
                <Button Content="Ajouter un élément" Margin="0,0,6,0" Click="AddEntry_Click"
                        Style="{StaticResource FluentButton}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Grid.Column="1">
                <Button Content="Supprimer" Margin="0,0,6,0" Click="DeleteClient_Click"
                        Style="{StaticResource FluentDangerButton}"/>
                <Button Content="Fermer" Click="Close_Click"
                        Style="{StaticResource FluentSubtleButton}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
