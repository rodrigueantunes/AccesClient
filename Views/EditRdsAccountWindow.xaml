<Window x:Class="AccesClientWPF.Views.EditRdsAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Éditer un compte" Height="250" Width="400"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/FluentTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Description :" Grid.Row="0" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
        <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Margin="120,0,0,5" Style="{StaticResource FluentTextBox}"/>

        <TextBlock Text="IP/DNS :" Grid.Row="1" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
        <TextBox Text="{Binding IpDns, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Margin="120,0,0,5" Style="{StaticResource FluentTextBox}"/>

        <TextBlock Text="Nom d'utilisateur :" Grid.Row="2" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
        <TextBox Text="{Binding NomUtilisateur, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Margin="120,0,0,5" Style="{StaticResource FluentTextBox}"/>

        <TextBlock Text="Mot de passe :" Grid.Row="3" FontWeight="Bold" Foreground="{StaticResource FluentTextPrimaryBrush}" FontFamily="{StaticResource FluentFont}"/>
        <PasswordBox Name="PasswordBox" Grid.Row="3" Margin="120,0,0,5" Style="{StaticResource FluentTextBox}"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left" Margin="157,0,0,0" Width="223">
            <Button Content="Annuler" Width="80" Margin="5" Click="Cancel_Click" Style="{StaticResource FluentSubtleButton}"/>
            <Button Content="Enregistrer" Width="123" Margin="5" Click="Save_Click" Style="{StaticResource FluentButton}"/>
        </StackPanel>
    </Grid>
</Window>
