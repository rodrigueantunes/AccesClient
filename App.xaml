<Application x:Class="AccesClientWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:AccesClientWPF.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/FluentTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <conv:FileTypeToIconConverter x:Key="FileTypeToIconConverter"/>

            <Style x:Key="RoundedButton" TargetType="Button" BasedOn="{StaticResource FluentButton}"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>