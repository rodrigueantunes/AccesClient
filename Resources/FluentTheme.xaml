<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Couleurs primaires -->
    <Color x:Key="FluentBrandColor">#0078D4</Color>
    <Color x:Key="FluentBrandHoverColor">#106EBE</Color>
    <Color x:Key="FluentBrandPressedColor">#005A9E</Color>
    <Color x:Key="FluentSurfaceColor">#F5F5F5</Color>
    <Color x:Key="FluentCardColor">#FFFFFF</Color>
    <Color x:Key="FluentSidebarColor">#2D2D2D</Color>
    <Color x:Key="FluentSidebarHoverColor">#3D3D3D</Color>
    <Color x:Key="FluentTextPrimaryColor">#1A1A1A</Color>
    <Color x:Key="FluentTextSecondaryColor">#616161</Color>
    <Color x:Key="FluentTextOnDarkColor">#FFFFFF</Color>
    <Color x:Key="FluentDividerColor">#E0E0E0</Color>
    <Color x:Key="FluentDangerColor">#D13438</Color>
    <Color x:Key="FluentSuccessColor">#107C10</Color>
    <Color x:Key="FluentWarningColor">#FFB900</Color>

    <!-- Couleurs supplémentaires pour le thème UI -->
    <Color x:Key="LightGrayColor">#F0F0F0</Color>
    <Color x:Key="VeryLightBlueColor">#E5F1FB</Color>
    <Color x:Key="DarkBlueColor">#0063B1</Color>
    <Color x:Key="WindowBackgroundColor">#EAEDED</Color>
    <Color x:Key="DarkBorderColor">#D0D0D0</Color>
    <Color x:Key="LightBorderColor">#E8E8E8</Color>
    <Color x:Key="DarkListBackgroundColor">#3A3A3A</Color>
    <Color x:Key="DarkHoverColor">#4A4A4A</Color>
    <Color x:Key="DarkTextColor">#2C3E50</Color>
    <Color x:Key="MediumTextColor">#34495E</Color>
    <Color x:Key="LightTextColor">#7F8C8D</Color>
    <Color x:Key="CreamColor">#FDF6E3</Color>
    <Color x:Key="CardBorderColor">#D5DBDB</Color>
    <Color x:Key="PureWhiteColor">#FDFEFE</Color>
    <Color x:Key="MediumGrayColor">#A0A0A0</Color>
    <Color x:Key="VeryLightBorderColor">#ECECEC</Color>
    <Color x:Key="ButtonGrayColor">#F8F9F9</Color>
    <Color x:Key="ButtonBorderColor">#AEB6BF</Color>
    <Color x:Key="HoverGrayColor">#E8E8E8</Color>

    <!-- Brushes primaires -->
    <SolidColorBrush x:Key="FluentBrandBrush" Color="{StaticResource FluentBrandColor}"/>
    <SolidColorBrush x:Key="FluentBrandHoverBrush" Color="{StaticResource FluentBrandHoverColor}"/>
    <SolidColorBrush x:Key="FluentBrandPressedBrush" Color="{StaticResource FluentBrandPressedColor}"/>
    <SolidColorBrush x:Key="FluentSurfaceBrush" Color="{StaticResource FluentSurfaceColor}"/>
    <SolidColorBrush x:Key="FluentCardBrush" Color="{StaticResource FluentCardColor}"/>
    <SolidColorBrush x:Key="FluentSidebarBrush" Color="{StaticResource FluentSidebarColor}"/>
    <SolidColorBrush x:Key="FluentSidebarHoverBrush" Color="{StaticResource FluentSidebarHoverColor}"/>
    <SolidColorBrush x:Key="FluentTextPrimaryBrush" Color="{StaticResource FluentTextPrimaryColor}"/>
    <SolidColorBrush x:Key="FluentTextSecondaryBrush" Color="{StaticResource FluentTextSecondaryColor}"/>
    <SolidColorBrush x:Key="FluentTextOnDarkBrush" Color="{StaticResource FluentTextOnDarkColor}"/>
    <SolidColorBrush x:Key="FluentDividerBrush" Color="{StaticResource FluentDividerColor}"/>
    <SolidColorBrush x:Key="FluentDangerBrush" Color="{StaticResource FluentDangerColor}"/>
    <SolidColorBrush x:Key="FluentSuccessBrush" Color="{StaticResource FluentSuccessColor}"/>
    <SolidColorBrush x:Key="FluentWarningBrush" Color="{StaticResource FluentWarningColor}"/>

    <!-- Brushes supplémentaires -->
    <SolidColorBrush x:Key="HoverBrush" Color="#E8E8E8"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#C42B2F"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#A52325"/>
    <SolidColorBrush x:Key="SubtlePressedBrush" Color="#D0D0D0"/>
    <SolidColorBrush x:Key="TextBoxHoverBrush" Color="#A0A0A0"/>
    <SolidColorBrush x:Key="LightGrayBrush" Color="{StaticResource LightGrayColor}"/>
    <SolidColorBrush x:Key="VeryLightBlueBrush" Color="{StaticResource VeryLightBlueColor}"/>
    <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlueColor}"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="DarkBorderBrush" Color="{StaticResource DarkBorderColor}"/>
    <SolidColorBrush x:Key="LightBorderBrush" Color="{StaticResource LightBorderColor}"/>
    <SolidColorBrush x:Key="DarkListBackgroundBrush" Color="{StaticResource DarkListBackgroundColor}"/>
    <SolidColorBrush x:Key="DarkHoverBrush" Color="{StaticResource DarkHoverColor}"/>
    <SolidColorBrush x:Key="DarkTextBrush" Color="{StaticResource DarkTextColor}"/>
    <SolidColorBrush x:Key="MediumTextBrush" Color="{StaticResource MediumTextColor}"/>
    <SolidColorBrush x:Key="LightTextBrush" Color="{StaticResource LightTextColor}"/>
    <SolidColorBrush x:Key="CreamBrush" Color="{StaticResource CreamColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>
    <SolidColorBrush x:Key="PureWhiteBrush" Color="{StaticResource PureWhiteColor}"/>
    <SolidColorBrush x:Key="MediumGrayBrush" Color="{StaticResource MediumGrayColor}"/>
    <SolidColorBrush x:Key="VeryLightBorderBrush" Color="{StaticResource VeryLightBorderColor}"/>
    <SolidColorBrush x:Key="ButtonGrayBrush" Color="{StaticResource ButtonGrayColor}"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource ButtonBorderColor}"/>
    <SolidColorBrush x:Key="HoverGrayBrush" Color="{StaticResource HoverGrayColor}"/>

    <FontFamily x:Key="FluentFont">Segoe UI Variable, Segoe UI, sans-serif</FontFamily>

    <Style x:Key="FluentButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource FluentBrandBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="16,8"
                            BorderThickness="1"
                            BorderBrush="Transparent">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource FluentBrandHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource FluentBrandPressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FluentSubtleButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="8,6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SubtlePressedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FluentDangerButton" TargetType="Button" BasedOn="{StaticResource FluentButton}">
        <Setter Property="Background" Value="{StaticResource FluentDangerBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="16,8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerPressedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FluentTextBox" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource FluentFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#D0D0D0"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource FluentBrandBrush}"/>
                            <Setter TargetName="Bd" Property="BorderThickness" Value="1,1,1,2"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource TextBoxHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FluentCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluentCardBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#E8E8E8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.08" Direction="270"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FluentPanelStyle" TargetType="Panel">
        <Setter Property="Background" Value="{StaticResource FluentBrandBrush}"/>
    </Style>

    <Style x:Key="FluentPasswordBox" TargetType="PasswordBox">
        <Setter Property="FontFamily" Value="{StaticResource FluentFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#D0D0D0"/>
        <Setter Property="Background" Value="White"/>
    </Style>

</ResourceDictionary>
